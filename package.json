{
  "name": "zksync-root",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  
  // =======================================================
  // WORKSPACES (Monorepo Configuration)
  // =======================================================
  "workspaces": {
    "packages": [
      "sdk/zksync.js",
      "sdk/zksync-crypto",
      "contracts",
      "infrastructure/zk",
      "infrastructure/reading-tool",
      "infrastructure/token-lists-manager",
      "infrastructure/api-docs",
      "core/tests/ts-tests"
    ]
  },
  
  // =======================================================
  // SCRIPTS (Simplified Build & Core Commands)
  // OPTIMIZATION: Removed redundant 'yarn workspace' aliases (zksync, crypto, etc.)
  // =======================================================
  "scripts": {
    // Build scripts directly calling the workspace command
    "build:zksync-sdk": "yarn workspace zksync prepublish",
    "build:crypto": "yarn workspace zksync-crypto build",
    "build:reading-tool": "yarn workspace reading-tool build",
    
    // Core maintenance scripts
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  
  // =======================================================
  // DEVELOPMENT DEPENDENCIES (MODERNIZED AND UPDATED)
  // OPTIMIZATION: All dependencies updated to the latest stable versions for security and features.
  // =======================================================
  "devDependencies": {
    // === LINTING & PARSERS (UPDATED) ===
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    // Replaced legacy 'babel-eslint' with the modern Babel parser
    "@babel/eslint-parser": "^7.23.10", 
    "eslint": "^8.57.0",
    "eslint-config-alloy": "^5.1.2",
    
    // === FORMATTING & DOCS (UPDATED) ===
    "prettier": "^3.2.5",
    "prettier-plugin-solidity": "^2.1.0",
    "markdown-toc": "^1.2.0",
    "markdownlint-cli": "^0.39.0",
    
    // === SOLIDITY LINTING (UPDATED) ===
    "solhint": "^4.0.0" 
  },
  
  // OPTIMIZATION: Added engines constraint for clarity on required Node.js version.
  "engines": {
    "node": ">=18.0.0"
  }
}
